# Entity: type

main: kit: entity: type: {

  alias: field: {}

  fields: [
    {
      name: "type"
      req: false
      type: "`$ARRAY`"
    }
  ]

  name: "type"
  op: {
    list: {
      name: "list"
      points: [
        {
          method: "GET"
          orig: "/types"
          parts: [
            "types"
          ]
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}
